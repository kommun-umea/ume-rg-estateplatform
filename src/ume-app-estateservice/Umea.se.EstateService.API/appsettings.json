{
  "KeyVaultUrl": "https://umekvestateplatformdev.vault.azure.net/",
  "ConnectionStrings": {
    "EstateService": "@KeyVault(estateservice-database-connection-string)"
  },
  "Features": "EstateService,ContactPersons,Documents,ErrorReport",
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Umea": "Trace",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "OpenTelemetry": {
      "LogLevel": {
        "Default": "Warning",
        "Umea.se": "Information",
        "Azure.Core": "Error",
        "Azure.Storage": "Error"
      }
    }
  },
  "AllowedHosts": "*",
  "Api": {
    "Name": "EstateService",
    "Title": "Umea.se.EstateService",
    "Description": "Api med koppling mot fastighetsystem",
    "Version": "v1.0",
    "Keys": {
      "Default": "@KeyVault(estateservice-api-key)"
    }
  },
  "Authentication": {
    "TokenServiceUrl": "https://authtokendev.umea.se",
    "Audience": "internal:mypage"
  },
  "OpenAI": {
    "Enabled": true,
    "Endpoint": "@KeyVault(openai-endpoint)",
    "Model": "gpt-5-nano"
  },
  "Pythagoras": {
    "ApiKey": "@KeyVault(pythagoras-api-key)",
    "BaseUrl": "@KeyVault(pythagoras-api-url)"
  },
  "ApplicationInsights": {
    "ConnectionString": "@KeyVault(application-insights-connection-string)"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:8080",
      "https://minasidor.dev.umea.se",
      "https://authtokendev.umea.se",
      "https://estate.dev.umea.se",
      "https://estateservice.dev.umea.se"
    ]
  },
  "DataSync": {
    "Schedule": "0 2 * * 0"
  },
  "Search": {
    "ExcludeRoomsFromSearch": true
  },
  "ImageCache": {
    "LifetimeHours": 24,
    "MetadataExpirationHours": 24,
    "BlobServiceUrl": "https://umestestateplatformdev.blob.core.windows.net",
    "BlobContainerName": "ume-stc-imagecache-dev"
  },
  "WorkOrder": {
    "DocumentActionTypeId": 4, // Protokoll / Handlingar
    "DocumentActionTypeStatusId": 7, // Övriga handlingar
    "FileStorage": "https://umestestateplatformdev.blob.core.windows.net",
    "FileStorageContainer": "workorder-files",

    // Background sync
    "ProcessingIntervalSeconds": 30,
    "MaxRetries": 5,
    "RetryBaseDelaySeconds": 60,
    "StatusCheckIntervalMinutes": 60
  }
}
